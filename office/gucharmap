abi <abi/4.0>,

include <tunables/global>

@{exec_pathGUC} = @{bin}/gucharmap
@{att} = /
profile gucharmap @{exec_pathGUC} flags=(attach_disconnected, attach_disconnected.path=@{att}) {
  include <abstractions/attached/base>
  include <abstractions/app/bwrap-glycin>
  include <abstractions/attached/consoles>
  include <abstractions/dconf>
  include <abstractions/fonts-strict>
  include <abstractions/graphics>
  include <abstractions/gtk-strict>
  include <abstractions/fontconfig-cache-read>
  include <abstractions/mime>
  include <abstractions/attached/nameservice-strict>
  include <abstractions/X-strict>

  signal (read) set=(kill,term) peer=lxqt-session,

  @{exec_pathGUC} mr,

  @{bin}/bwrap                          Px -> gucharmap//&glycin,
  @{lib}/glycin-loaders/@{d}+/glycin-*  Px -> gucharmap//&glycin//&glycin//loaders,

  /usr/share/icons/{,**} r,
  /usr/share/glib-2.0/schemas/gschemas.compiled r,
  /usr/share/themes/Default/gtk-3.0/gtk-keys.css r,
  /usr/share/pixmaps/{,**} r,

  / r,

  owner @{user_share_dirs}/sddm/wayland-session.log w,

  @{PROC}/@{pid}/cgroup r,
  owner @{PROC}/@{pid}/maps r,

  @{sys}/fs/cgroup/user.slice/cpu.max r,
  @{sys}/fs/cgroup/user.slice/user-@{uid}.slice/cpu.max r,
  @{sys}/fs/cgroup/user.slice/user-@{uid}.slice/session-@{int}.scope/cpu.max r,

  owner /tmp/gdk-pixbuf-glycin-tmp.@{rand6} rw,

}

# vim:syntax=apparmor
  
