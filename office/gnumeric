abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/gnumeric @{bin}/gnumeric-?.??.??
@{att} = /att/gnumeric/
profile gnumeric /{{,usr/}bin/gnumeric,{,usr/}bin/gnumeric-?.??.??} flags=(attach_disconnected, attach_disconnected.path=@{att}) {
  include <abstractions/attached/base>
  include <abstractions/audio-client>
  include <abstractions/attached/consoles>
  include <abstractions/app/bwrap-glycin>
  include <abstractions/bus-session>
  include <abstractions/bus/session/org.freedesktop.FileManager1>
  include <abstractions/bus/session/org.gtk.vfs.Mountable>
  include <abstractions/cups-client>
  include <abstractions/dconf-write>
  include <abstractions/fonts-strict>
  include <abstractions/fontconfig-cache-read>
  include <abstractions/lxqt>
  include <abstractions/graphics>
  include <abstractions/attached/nameservice-strict>
  include <abstractions/thumbnails-cache-read>
  include <abstractions/user-read-strict>
  include <abstractions/user-write-strict>
  
  signal (read) set=(kill,term) peer=lxqt-session,

  @{exec_path}			mr,

  @{bin}/bwrap                          Px -> gnumeric//&glycin,
  @{lib}/glycin-loaders/@{d}+/glycin-*  Px -> gnumeric//&glycin//&glycin//loaders,

  @{sh_path}        			rix,
  @{bin}/basename   rix,
  @{bin}/dirname    rix,
  @{bin}/{,e}grep       		rix,
  @{bin}/ls         rix,
  @{bin}/paperconf  			rix,

  / r,

  /usr/share/icons/{,**} r,
  /usr/share/mime/{,**} r,
  /usr/share/thumbnailers/{,**} r,
  /usr/share/libfm-qt6/translations/libfm-qt_de.qm r,
  /usr/share/featherpad/translations/featherpad_de.qm r,
  /usr/share/gnumeric/{,**} r,
  /usr/share/sounds/freedesktop/index.theme r,

  /etc/ r,
  /etc/fstab r,
  /etc/cups/client.conf r, 
  /etc/arch-release r,

  owner @{HOME}/.xscreensaver r,
  owner @{HOME}/.icons/default/index.theme r,

  owner @{user_config_dirs}/#@{int} rw,

  owner @{user_share_dirs}/gvfs-metadata/home r,
  owner @{user_share_dirs}/sddm/xorg-session.log w,
  owner @{user_share_dirs}/sddm/wayland-session.log w,

  owner @{user_cache_dirs}/thumbnails/ rw,

  /tmp/ r,
  owner /tmp/#@{int}		rw,

  @{sys}/fs/cgroup/user.slice/user-@{uid}.slice/session-@{int}.scope/cpu.max r,
  @{sys}/fs/cgroup/user.slice/user-@{uid}.slice/cpu.max r,
  @{sys}/fs/cgroup/user.slice/cpu.max r,

  owner @{PROC}/@{pid}/cgroup r,
  owner @{PROC}/@{pid}/mountinfo r,
  owner @{PROC}/@{pid}/mounts r,

  /dev/tty						rw,
  owner /dev/tty@{u8} rw,

  owner /tmp/gtkprint_ppd_@{rand6} rw,

  deny owner @{user_share_dirs}/gvfs-metadata/*.log rw,
  deny owner @{HOME}/.* rw,
  deny /etc/passwd  r,
  
  include if exists <local/abiword>
}

# vim:syntax=apparmor
